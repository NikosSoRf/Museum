<h1>Добавление нового экспоната</h1>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Музейный каталог</title>
    <link rel="stylesheet" type="text/css" href="/css/styles.css">
</head>
<form action="/exhibits" method="POST" class="exhibit-form" enctype="application/x-www-form-urlencoded">
    <div class="form-group">
        <label for="name">Название:</label>
        <input type="text" id="name" name="name" required>
    </div>
    
    <div class="form-group">
        <label for="description">Описание:</label>
        <textarea id="description" name="description" required></textarea>
    </div>
    
    <div class="form-row">
        <div class="form-group">
            <label for="creationDate">Дата создания:</label>
            <input type="date" id="creationDate" name="creationDate" required>
        </div>
        
        <div class="form-group">
            <label for="author">Автор:</label>
            <input type="text" id="author" name="author" required>
        </div>
    </div>
    
    <div class="form-row">
        <div class="form-group">
            <label for="collectionType">Тип коллекции:</label>
            <select id="collectionType" name="collectionType" required>
                <option value="painting">Картина</option>
                <option value="sculpture">Скульптура</option>
                <option value="artifact">Артефакт</option>
                <option value="document">Документ</option>
                <option value="other">Другое</option>
            </select>
        </div>
        
        <div class="form-group">
            <label for="location">Местоположение:</label>
            <input type="text" id="location" name="location" required>
        </div>
    </div>
    
    <div class="form-group checkbox">
        <input type="checkbox" id="isOnDisplay" name="isOnDisplay">
        <label for="isOnDisplay">Находится на выставке</label>
    </div>
    
    <div class="form-actions">
        <button type="submit" class="btn primary">Сохранить</button>
        <a href="/" class="btn secondary">Отмена</a>
    </div>
</form>